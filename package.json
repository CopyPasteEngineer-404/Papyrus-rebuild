{
  "name": "papyrus",
  "version": "1.0.0",
  "private": true,
  "description": "Offline-first document transformation engine — convert any format to any format",
  "type": "module",
  "main": "src/desktop/bun/index.ts",
  "bin": {
    "papyrus": "src/cli/index.ts"
  },
  "scripts": {
    "papy": "tsx src/cli/index.ts",
    "papyrus": "tsx src/cli/index.ts",
    "cli": "tsx src/cli/index.ts",
    "app": "bun run src/desktop/bun/index.ts",
    "dev": "electrobun dev",
    "dev:cli": "bun run src/cli/index.ts",
    "build": "electrobun build",
    "build:stable": "electrobun build --env=stable",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-dropdown-menu": "^2.1.18",
    "@radix-ui/react-scroll-area": "^1.2.12",
    "@radix-ui/react-select": "^2.3.1",
    "@radix-ui/react-separator": "^1.1.10",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-switch": "^1.3.1",
    "@radix-ui/react-tabs": "^1.1.15",
    "@radix-ui/react-tooltip": "^1.2.10",
    "blessed": "^0.1.81",
    "chalk": "^5.3.0",
    "cheerio": "^1.0.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "commander": "^12.1.0",
    "docx": "^9.0.0",
    "epub-gen": "^0.1.0",
    "epub2": "^3.0.2",
    "framer-motion": "^12.40.0",
    "glob": "^10.3.0",
    "lucide-react": "^0.400.0",
    "mammoth": "^1.8.0",
    "ora": "^8.0.0",
    "pdf-lib": "^1.17.1",
    "pptx-parser": "^1.0.0",
    "pptxgenjs": "^3.12.0",
    "rtf-parser": "^1.0.0",
    "sonner": "^1.5.0",
    "tailwind-merge": "^2.3.0",
    "xlsx": "^0.18.5",
    "yaml": "^2.4.0",
    "zod": "^3.23.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/blessed": "^0.1.27",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.22.4",
    "typescript": "^5.8.2",
    "vite": "^5.4.0",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT"
}
