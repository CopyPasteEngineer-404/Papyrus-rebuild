    "commander": "^12.1.0",
    "docx": "^9.0.0",
    "epub-gen": "^0.1.0",
    "epub2": "^3.0.2",
    "glob": "^10.3.0",
    "mammoth": "^1.8.0",
    "ora": "^8.0.0",
    "pdf-lib": "^1.17.1",
    "pptx-parser": "^1.0.0",
    "pptxgenjs": "^3.12.0",
    "rtf-parser": "^1.0.0",
